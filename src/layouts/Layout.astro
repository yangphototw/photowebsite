---
import { ClientRouter } from 'astro:transitions';

interface Props {
	title?: string;
}

const { title = "Yang Photography" } = Astro.props;
const pathname = new URL(Astro.url).pathname;

// 導覽定義：多類別雙語導覽，維持細緻字體
const navItems = [
	{ name: 'Home / 首頁', href: '/' },
	{ name: 'Wedding / 婚禮', href: '/wedding' },
	{ name: 'Travel / 旅遊', href: '/travel' },
	{ name: 'Portrait / 人像', href: '/portrait' },
	{ name: 'Product / 商品', href: '/product' },
	{ name: 'Event / 活動紀錄', href: '/event' },
	{ name: 'About / 關於', href: '/about' },
	{ name: 'Contact / 聯絡', href: '/contact' },
];
---

<!doctype html>
<html lang="zh-TW" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		
		<!-- 載入優雅文藝感的襯線體與極細無襯線體 -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Inter:wght@100..300&display=swap" rel="stylesheet">
		
		<title>{title}</title>
		<ClientRouter />
		<style is:global>
			@import "tailwindcss";

			:root {
				--color-gray-soft: #9CA3AF;
				--font-serif: 'Playfair Display', serif;
				--font-sans: 'Inter', sans-serif;
			}

			body {
				background-color: #000000;
				color: var(--color-gray-soft);
				font-family: var(--font-sans);
				font-weight: 200; /* 極細無襯線體 */
				-webkit-font-smoothing: antialiased;
			}

			h1, h2, h3, .brand-font {
				font-family: var(--font-serif);
			}

			/* 移除所有預設的外框選取 */
			*:focus {
				outline: none;
			}
		</style>
	</head>
	<body class="bg-black text-[#9CA3AF] font-sans font-[200] min-h-screen flex flex-col selection:bg-zinc-800 selection:text-white antialiased">
		<!-- 頂部導覽：極大垂直留白，營造高級感 -->
		<header class="w-full py-12 px-8 md:px-16 max-w-7xl mx-auto">
			<nav class="flex flex-col md:flex-row justify-between items-baseline gap-8">
				<!-- 左側：攝影師名字，加大尺寸襯線體 -->
				<a href="/" class="brand-font text-3xl md:text-4xl text-white tracking-wide hover:opacity-70 transition-opacity">
					Yang
				</a>

				<!-- 右側：極細導覽連結 -->
				<ul class="flex flex-wrap justify-center md:justify-end gap-x-6 gap-y-4 text-[9px] md:text-[10px] tracking-[0.2em] font-light uppercase">
					{navItems.map((item) => (
						<li>
							<a 
								href={item.href} 
								class={`hover:text-white transition-colors duration-500 py-1 border-b border-transparent hover:border-white/30 ${
									pathname === item.href || (item.href !== '/' && pathname.startsWith(item.href))
									? 'text-white !border-white/50'
									: ''
								}`}
							>
								{item.name}
							</a>
						</li>
					))}
				</ul>
			</nav>
		</header>

		<!-- 頁面主要容器：寬鬆留白 -->
		<main class="flex-grow w-full px-8 md:px-16 max-w-7xl mx-auto">
			<slot />
		</main>

		<!-- 頁尾：低調且克制 -->
		<footer class="w-full py-20 px-8 md:px-16 max-w-7xl mx-auto">
			<div class="border-t border-zinc-900 pt-8 flex justify-between items-center text-[10px] tracking-widest uppercase text-zinc-600">
				<p>&copy; 2026 YANG PHOTOGRAPHY</p>
			</div>
		</footer>
	</body>
</html>
