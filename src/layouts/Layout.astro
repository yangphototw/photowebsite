---
import { ClientRouter } from 'astro:transitions';

interface Props {
	title?: string;
	fullWidth?: boolean;
}

const { title = "Yang Photography", fullWidth = false } = Astro.props;
const pathname = new URL(Astro.url).pathname;

// 導覽定義：多類別雙語導覽，維持細緻字體
const navItems = [
	{ name: 'Home / 首頁', href: '/' },
	{ name: 'Wedding / 婚禮', href: '/wedding' },
	{ name: 'Registration / 登記', href: '/registration' },
	{ name: 'Portrait / 人像', href: '/portrait' },
	{ name: 'Travel / 旅遊', href: '/travel' },
	{ name: 'Product / 商品', href: '/product' },
	{ name: 'Event / 活動紀錄', href: '/event' },
	{ name: 'About / 關於', href: '/about' },
	{ name: 'Contact / 聯絡', href: '/contact' },
];
---

<!doctype html>
<html lang="zh-TW" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		
		<!-- 載入核心字體：Inter (英文) + Noto Sans TC (中文) -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&family=Noto+Sans+TC:wght@100..900&display=swap" rel="stylesheet">
		
		<title>{title}</title>
		<ClientRouter />
		<style is:global>
			@import "tailwindcss";

			:root {
				--color-gray-soft: #9CA3AF;
				--font-base: 'Inter', 'Noto Sans TC', sans-serif;
			}

			html {
				overflow-y: scroll; /* 強制永遠顯示捲軸，確保全站寬度一致 */
				scrollbar-gutter: stable;
			}

			body {
				background-color: #000000;
				color: var(--color-gray-soft);
				font-family: var(--font-base);
				font-weight: 200; /* 保持原字重 */
				-webkit-font-smoothing: antialiased;
			}

			h1, h2, h3, .brand-font {
				font-family: var(--font-base);
				font-weight: 200; /* 保持原字重，將標題也統一為黑體 */
			}

			/* 移除所有預設的外框選取 */
			*:focus {
				outline: none;
			}
		</style>
	</head>
	<body class="bg-black text-[#9CA3AF] font-sans font-[200] min-h-screen flex flex-col selection:bg-zinc-800 selection:text-white antialiased relative">
		<!-- 頂部導覽：改為 absolute 絕對定位，徹底釋放物理空間，讓首頁大圖完美貼頂 -->
		<header class="absolute top-0 left-0 w-full py-8 md:py-12 px-8 md:px-16 z-50 pointer-events-none">
			<div class="max-w-7xl mx-auto w-full">
				<nav class="flex justify-center pointer-events-auto">
					<!-- 極細導覽連結：已改為全站置中，移除所有 Logo -->
					<ul class="flex flex-wrap justify-center gap-x-8 gap-y-4 text-[9px] md:text-[10px] tracking-[0.2em] font-light uppercase">
						{navItems.map((item) => (
							<li>
								<a 
									href={item.href} 
									class={`hover:text-white transition-colors duration-500 py-1 border-b border-transparent hover:border-white/30 ${
										pathname === item.href || (item.href !== '/' && pathname.startsWith(item.href))
										? 'text-white !border-white/50'
										: ''
									}`}
								>
									{item.name}
								</a>
							</li>
						))}
					</ul>
				</nav>
			</div>
		</header>

		<!-- 頁面主要容器：依據設定決定是否滿版。若是滿版則不加 padding，若否則加上適當的 top padding 避開 absolute header -->
		<main class={`flex-grow w-full ${fullWidth ? '' : 'pt-32 px-8 md:px-16 max-w-7xl mx-auto'}`}>
			<slot />
		</main>

		<!-- 頁尾：低調且克制 -->
		<footer class="w-full py-20 px-8 md:px-16 max-w-7xl mx-auto">
			<div class="border-t border-zinc-900 pt-8 flex justify-between items-center text-[10px] tracking-widest uppercase text-zinc-600">
				<p>&copy; 2026 YANG PHOTOGRAPHY</p>
			</div>
		</footer>
	</body>
</html>
