---
import { ClientRouter } from 'astro:transitions';

interface Props {
	title?: string;
}

const { title = "Astro Photography" } = Astro.props;
const pathname = new URL(Astro.url).pathname;

// 導覽項目定義
const navItems = [
	{ name: 'Home / 首頁', href: '/' },
	{ name: 'Wedding / 婚禮', href: '/wedding' },
	{ name: 'Travel / 旅遊', href: '/travel' },
	{ name: 'Portrait / 人像', href: '/portrait' },
	{ name: 'Product / 商品', href: '/product' },
	{ name: 'About / 關於', href: '/about' },
	{ name: 'Contact / 聯絡', href: '/contact' },
];
---

<!doctype html>
<html lang="zh-TW" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Photography Portfolio" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Syne:wght@800&display=swap" rel="stylesheet">
		<title>{title}</title>
		<ClientRouter />
		<style>
			@import "tailwindcss";
		</style>
	</head>
	<body class="text-gray-300 font-sans min-h-screen flex flex-col bg-fixed" style="background: radial-gradient(circle at 50% 30%, #0f0f0f 0%, #000000 100%);">
		<nav class="flex flex-col md:flex-row justify-between items-center px-8 py-10 max-w-7xl mx-auto w-full gap-8">
			<a href="/" class="text-4xl font-extrabold tracking-tighter text-white hover:opacity-80 transition-opacity uppercase" style="font-family: 'Syne', sans-serif;">
				Yang
			</a>
			<div class="flex flex-wrap justify-center gap-x-6 gap-y-3 text-[10px] md:text-xs font-bold tracking-[0.2em] uppercase">
				{navItems.map((item) => {
					// 判斷是否為當前頁面 (首頁需精準匹配，其他頁面採前綴匹配以包含子分頁)
					const isActive = item.href === '/' 
						? pathname === '/' 
						: pathname.startsWith(item.href);

					return (
						<a 
							href={item.href} 
							class={`pb-1 border-b-2 transition-all duration-300 hover:text-white ${
								isActive 
								? 'text-white border-white/40' 
								: 'border-transparent hover:border-white/10'
							}`}
						>
							{item.name}
						</a>
					);
				})}
			</div>
		</nav>

		<main class="flex-grow max-w-7xl mx-auto w-full px-8">
			<slot />
		</main>

		<footer class="px-8 py-16 text-center text-zinc-600 text-xs tracking-widest uppercase">
			<p>&copy; 2026 Photography Portfolio. Built with Astro & Tailwind.</p>
		</footer>
	</body>
</html>
