---
import Layout from '../layouts/Layout.astro';
import fs from 'node:fs';
import path from 'node:path';

// 改用 fs 讀取以確保 SSR 環境穩定
const albumsPath = path.resolve('src/data/albums.json');
const albums = JSON.parse(fs.readFileSync(albumsPath, 'utf-8'));

// 首頁展示最新的幾個專案作為精選
const featuredAlbums = albums.slice(0, 6);
---

<Layout title="Selected Works | Photography Portfolio">
	<!-- Hero Section -->
	<section class="py-12 md:py-24 animate-fade-in">
		<h1 class="text-6xl md:text-8xl font-black tracking-tighter text-white mb-4 uppercase">
			Vision &<br />Narrative
		</h1>
		<p class="text-zinc-500 text-lg md:text-xl font-light tracking-wide max-w-2xl">
			每一張照片都是一段靜止的敘事。透過光影的捕捉，我們重構瞬間的情感與氛圍。
		</p>
	</section>

	<!-- Featured Projects Grid -->
	<div class="grid grid-cols-1 md:grid-cols-2 gap-8 pb-32">
		{featuredAlbums.length > 0 ? (
			featuredAlbums.map((album) => (
				<a href={`/portfolio/${album.categorySlug}/${album.projectSlug}`} class="group block relative overflow-hidden bg-zinc-900 aspect-[16/9] animate-fade-in">
					<img
						src={album.cover}
						alt={album.project}
						class="w-full h-full object-cover opacity-60 group-hover:opacity-100 group-hover:scale-105 transition-all duration-1000 ease-out"
					/>
					<div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-60 group-hover:opacity-100 transition-opacity"></div>
					<div class="absolute bottom-8 left-8">
						<span class="text-[10px] tracking-[0.3em] uppercase text-zinc-400 font-bold mb-2 block">{album.category}</span>
						<h2 class="text-3xl font-bold text-white tracking-tight">{album.project}</h2>
					</div>
				</a>
			))
		) : (
			<div class="col-span-full py-20 text-center text-zinc-500 italic">
				尚未處理照片，請先執行圖片處理腳本。
			</div>
		)}
	</div>

	<style>
		@keyframes fadeIn {
			from { opacity: 0; transform: translateY(20px); }
			to { opacity: 1; transform: translateY(0); }
		}
		.animate-fade-in {
			animation: fadeIn 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
		}
	</style>
</Layout>
