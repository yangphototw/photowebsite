---
import Layout from '../layouts/Layout.astro';
import fs from 'node:fs';
import path from 'node:path';

const readJson = (filePath: string) => {
	try {
		const fullPath = path.resolve(filePath);
		if (fs.existsSync(fullPath)) return JSON.parse(fs.readFileSync(fullPath, 'utf-8'));
	} catch (e) {}
	return [];
};

// 嘗試讀取 albums.json 來獲取最新處理的圖片
let albums = readJson('src/data/albums.json');
let allImages: string[] = [];
if (albums.length > 0) {
    allImages = albums.flatMap((a: any) => a.images);
} else {
    // 降級讀取舊版 images.json (若存在)
    const oldImages = readJson('src/data/images.json');
    allImages = oldImages.map((img: any) => img.src);
}

const defaultImg = "https://images.unsplash.com/photo-1492691527719-9d1e07e534b4?q=80&w=2000&auto=format&fit=crop";

const heroImage = allImages[0] || defaultImg;
const cardImg1 = allImages[1] || "https://images.unsplash.com/photo-1511895426328-dc8714191300?q=80&w=2000&auto=format&fit=crop";
const cardImg2 = allImages[2] || "https://images.unsplash.com/photo-1554046920-90dc20696342?q=80&w=2000&auto=format&fit=crop";
const cardImg3 = allImages[3] || "https://images.unsplash.com/photo-1515378960530-7c0da6229b92?q=80&w=2000&auto=format&fit=crop";

const igImg1 = allImages[4] || heroImage;
const igImg2 = allImages[5] || cardImg1;
const igImg3 = allImages[6] || cardImg2;
const igImg4 = allImages[7] || cardImg3;
---

<Layout title="Yang Photography | Luxury Visuals">
	<!-- 1. 電影感巨幕開場 (Hero Section) -->
	<section class="relative w-full h-[90vh] flex items-center mb-24 animate-fade-in -mt-[120px]">
		<!-- 背景大圖與漸層遮罩 -->
		<div class="absolute inset-0 z-0">
			<img src={heroImage} alt="Hero Background" class="w-full h-full object-cover opacity-80" />
			<div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/40 to-black"></div>
		</div>

		<!-- 左側內容區 -->
		<div class="relative z-10 w-full px-8 md:px-16 max-w-7xl mx-auto flex justify-between items-end h-full pb-20">
			<div class="flex flex-col items-start gap-6 max-w-3xl">
				<span class="text-[10px] md:text-xs tracking-[0.4em] text-zinc-400 font-light">
					DESTINATION WEDDING / PHOTOGRAPHER & FILMMAKER
				</span>
				
				<h1 class="brand-font text-5xl md:text-7xl lg:text-8xl text-white leading-tight">
					Timeless Stories. <br />
					Infinite Romance<span class="text-amber-400 drop-shadow-[0_0_8px_rgba(245,158,11,0.5)]">*</span>
				</h1>
				
				<p class="text-zinc-400 font-light tracking-wide text-sm md:text-base max-w-lg mb-4">
					Crafting editorial narratives infused with raw emotion and cinematic elegance.
				</p>
				
				<a href="/portrait" class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-md border border-amber-500/30 rounded-full px-8 py-4 text-xs md:text-sm text-amber-200 tracking-widest hover:bg-amber-500/20 hover:scale-105 hover:border-amber-500/50 transition-all duration-500">
					VIEW PORTFOLIO <span class="text-lg leading-none">↗</span>
				</a>
			</div>
			
			<!-- 右側垂直點綴 -->
			<div class="hidden md:flex flex-col items-center gap-6 absolute right-8 md:right-16 bottom-20">
				<span class="text-[9px] tracking-[0.3em] text-zinc-500 [writing-mode:vertical-rl] rotate-180">
					SCROLL TO EXPLORE
				</span>
				<div class="w-px h-16 bg-gradient-to-b from-zinc-500 to-transparent"></div>
			</div>
		</div>
	</section>

	<div class="max-w-7xl mx-auto px-8 md:px-16 w-full relative z-10">
		<!-- 2. 三大核心主題卡片 (The Grid Portfolio) -->
		<section class="mb-32 animate-fade-in-up delay-200">
			<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
				<!-- Card 01 -->
				<a href="/wedding" class="group block p-4 md:p-6 bg-zinc-900/40 backdrop-blur-md border border-amber-500/20 rounded-2xl hover:border-amber-500/50 hover:shadow-[0_0_30px_rgba(245,158,11,0.1)] transition-all duration-500">
					<div class="flex justify-between items-center mb-6 px-2">
						<span class="text-xs text-amber-500/80 font-bold tracking-widest">01</span>
						<h3 class="brand-font text-xl text-white tracking-wide">Weddings</h3>
					</div>
					<div class="relative w-full aspect-[3/4] overflow-hidden rounded-xl bg-black">
						<img src={cardImg1} class="w-full h-full object-cover opacity-70 brightness-75 group-hover:brightness-100 group-hover:opacity-100 group-hover:scale-[1.02] transition-all duration-700 ease-out" alt="Weddings" />
					</div>
				</a>

				<!-- Card 02 -->
				<a href="/portrait" class="group block p-4 md:p-6 bg-zinc-900/40 backdrop-blur-md border border-amber-500/20 rounded-2xl hover:border-amber-500/50 hover:shadow-[0_0_30px_rgba(245,158,11,0.1)] transition-all duration-500 md:-translate-y-8">
					<div class="flex justify-between items-center mb-6 px-2">
						<span class="text-xs text-amber-500/80 font-bold tracking-widest">02</span>
						<h3 class="brand-font text-xl text-white tracking-wide">Portraits</h3>
					</div>
					<div class="relative w-full aspect-[3/4] overflow-hidden rounded-xl bg-black">
						<img src={cardImg2} class="w-full h-full object-cover opacity-70 brightness-75 group-hover:brightness-100 group-hover:opacity-100 group-hover:scale-[1.02] transition-all duration-700 ease-out" alt="Portraits" />
					</div>
				</a>

				<!-- Card 03 -->
				<a href="/product" class="group block p-4 md:p-6 bg-zinc-900/40 backdrop-blur-md border border-amber-500/20 rounded-2xl hover:border-amber-500/50 hover:shadow-[0_0_30px_rgba(245,158,11,0.1)] transition-all duration-500">
					<div class="flex justify-between items-center mb-6 px-2">
						<span class="text-xs text-amber-500/80 font-bold tracking-widest">03</span>
						<h3 class="brand-font text-xl text-white tracking-wide">Editorials</h3>
					</div>
					<div class="relative w-full aspect-[3/4] overflow-hidden rounded-xl bg-black">
						<img src={cardImg3} class="w-full h-full object-cover opacity-70 brightness-75 group-hover:brightness-100 group-hover:opacity-100 group-hover:scale-[1.02] transition-all duration-700 ease-out" alt="Editorials" />
					</div>
				</a>
			</div>
		</section>

		<!-- 3. 底部品牌金句與社群區塊 (Footer Quotes & Social) -->
		<section class="grid grid-cols-1 md:grid-cols-2 gap-6 pb-20 animate-fade-in-up delay-500">
			<!-- 左下角：精緻雙引號金句 -->
			<div class="flex flex-col justify-center p-10 md:p-16 border border-zinc-800/50 rounded-2xl bg-zinc-900/20 relative overflow-hidden group hover:border-zinc-700 transition-colors duration-500">
				<span class="absolute top-8 left-8 text-7xl text-zinc-800 font-serif leading-none group-hover:text-amber-900/30 transition-colors duration-700">"</span>
				<p class="brand-font text-2xl md:text-3xl text-zinc-300 italic leading-relaxed tracking-wide relative z-10 pl-6">
					They didn't just capture our wedding.<br />
					They captured how it felt to be us.
				</p>
				<p class="text-[10px] tracking-widest text-zinc-500 uppercase mt-8 pl-6">
					— Anna & Marcus, Lake Como
				</p>
			</div>

			<!-- 右下角：分成兩個方塊 -->
			<div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
				<!-- 全球拍攝服務 -->
				<div class="p-8 bg-zinc-900/40 backdrop-blur-md border border-zinc-800/80 rounded-2xl flex flex-col items-center justify-center text-center group hover:bg-zinc-800/40 transition-colors">
					<div class="w-16 h-16 rounded-full border border-zinc-700 flex items-center justify-center mb-6 group-hover:border-amber-500/50 group-hover:shadow-[0_0_15px_rgba(245,158,11,0.2)] transition-all duration-500">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-400 group-hover:text-amber-400 transition-colors"><circle cx="12" cy="12" r="10"></circle><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"></path><path d="M2 12h20"></path></svg>
					</div>
					<h4 class="brand-font text-lg text-white mb-2">Available Worldwide</h4>
					<p class="text-[10px] text-zinc-500 tracking-widest uppercase">Based in Taiwan</p>
				</div>

				<!-- IG 預覽 -->
				<a href="#" class="p-6 bg-zinc-900/40 backdrop-blur-md border border-zinc-800/80 rounded-2xl flex flex-col justify-between group hover:border-amber-500/30 transition-colors">
					<h4 class="text-[10px] text-zinc-400 tracking-[0.2em] uppercase font-bold mb-4 flex items-center justify-between">
						Follow Along <span>↗</span>
					</h4>
					<div class="grid grid-cols-2 gap-2">
						<div class="aspect-square rounded-lg overflow-hidden bg-black">
							<img src={igImg1} class="w-full h-full object-cover opacity-60 group-hover:opacity-100 transition-opacity duration-500" alt="IG 1" />
						</div>
						<div class="aspect-square rounded-lg overflow-hidden bg-black">
							<img src={igImg2} class="w-full h-full object-cover opacity-60 group-hover:opacity-100 transition-opacity duration-500 delay-75" alt="IG 2" />
						</div>
						<div class="aspect-square rounded-lg overflow-hidden bg-black">
							<img src={igImg3} class="w-full h-full object-cover opacity-60 group-hover:opacity-100 transition-opacity duration-500 delay-150" alt="IG 3" />
						</div>
						<div class="aspect-square rounded-lg overflow-hidden bg-black flex items-center justify-center relative">
							<img src={igImg4} class="w-full h-full object-cover opacity-30 group-hover:opacity-60 transition-opacity duration-500 delay-200" alt="IG 4" />
							<span class="absolute text-white text-xs font-bold tracking-widest">+IG</span>
						</div>
					</div>
				</a>
			</div>
		</section>
	</div>

	<style>
		@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
		@keyframes fadeInUp { from { opacity: 0; transform: translateY(40px); } to { opacity: 1; transform: translateY(0); } }
		.animate-fade-in { animation: fadeIn 2s ease-out forwards; }
		.animate-fade-in-up { opacity: 0; animation: fadeInUp 1.5s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
	</style>
</Layout>
