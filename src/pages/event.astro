---
import Layout from '../layouts/Layout.astro';
import fs from 'node:fs';
import path from 'node:path';

// 讀取相簿資料
const albumsPath = path.resolve('src/data/albums.json');
const allAlbums = JSON.parse(fs.readFileSync(albumsPath, 'utf-8'));

// 篩選出「Event」類別下的專案
const targetAlbums = allAlbums.filter(album => album.category === "Event");

// 【智慧佈局判斷】: 如果該分類下只有一個自動生成的 "Gallery" 專案，則直接顯示瀑布流
const isDirectGallery = targetAlbums.length === 1 && targetAlbums[0].projectSlug === "gallery";
const directImages = isDirectGallery ? targetAlbums[0].images : [];

// 如果是專案模式，判斷 Grid 欄數
const count = targetAlbums.length;
const gridColsClass = count === 1 
    ? 'grid-cols-1 max-w-3xl mx-auto' 
    : count === 2 
    ? 'grid-cols-1 md:grid-cols-2 max-w-5xl mx-auto' 
    : 'grid-cols-1 md:grid-cols-2 lg:grid-cols-3';
---

<Layout title="Event | 活動紀錄">
	<!-- 極簡標題標識 -->
	<section class="py-8 md:py-12 animate-fade-in text-center flex flex-col items-center">
		<div class="flex items-center gap-3 text-zinc-500 font-light tracking-[0.4em] text-[10px] uppercase">
			<span>Event / 活動紀錄</span>
		</div>
        <div class="h-px w-12 bg-zinc-800 mt-4"></div>
	</section>

    {isDirectGallery ? (
        <section class="pb-32 animate-fade-in">
            <div class="columns-1 sm:columns-3 gap-6 space-y-6">
                {directImages.map((src) => (
                    <div class="break-inside-avoid overflow-hidden rounded-2xl bg-zinc-900 cursor-zoom-in group relative border border-zinc-800/50">
                        <img src={src} alt="Event Work" loading="lazy" class="w-full h-auto object-cover opacity-70 group-hover:opacity-100 group-hover:scale-[1.02] transition-all duration-700 ease-out lightbox-trigger" />
                    </div>
                ))}
            </div>
        </section>
    ) : targetAlbums.length > 0 ? (
        <div class={`grid ${gridColsClass} gap-12 md:gap-16 pb-32 animate-fade-in`}>
            {targetAlbums.map(album => (
                <div class="relative group">
                    <a href={`/portfolio/${album.categorySlug}/${album.projectSlug}`} class="block relative overflow-hidden rounded-2xl aspect-[3/4] bg-zinc-900 transition-all duration-700 hover:shadow-[0_0_80px_rgba(255,255,255,0.05)]">
                        <img src={album.cover} alt={album.project} class="w-full h-full object-cover opacity-60 group-hover:opacity-100 group-hover:scale-[1.05] transition-all duration-1000 ease-out" />
                        <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent opacity-80 group-hover:opacity-100 transition-opacity flex flex-col justify-end p-10">
                            <h3 class="text-2xl font-light text-white tracking-tight transform translate-y-2 group-hover:translate-y-0 transition-all duration-500">{album.project}</h3>
                            <div class="h-px w-0 group-hover:w-12 bg-white/50 mt-4 transition-all duration-700"></div>
                            <span class="text-[10px] text-zinc-400 uppercase tracking-[0.3em] font-medium mt-4 opacity-0 group-hover:opacity-100 transition-all duration-700 delay-100">Explore Story</span>
                        </div>
                    </a>
                    <div class="absolute -inset-4 bg-white/5 opacity-0 group-hover:opacity-100 blur-3xl rounded-full transition-opacity duration-1000 -z-10 pointer-events-none"></div>
                </div>
            ))}
        </div>
    ) : (
		<section class="py-24 text-center animate-fade-in">
			<p class="text-zinc-600 tracking-widest text-xs uppercase">Capturing the pulse of life.</p>
			<p class="text-zinc-800 mt-4 italic text-sm">No stories yet / 暫無作品</p>
		</section>
    )}

	<div id="lightbox" class="fixed inset-0 bg-black z-[100] hidden opacity-0 transition-opacity duration-500 flex items-center justify-center p-4 md:p-12">
		<div id="lightbox-backdrop" class="absolute inset-0 cursor-zoom-out"></div>
		<img id="lightbox-img" src="" class="relative z-10 max-w-full max-h-full object-contain shadow-2xl scale-95 transition-transform duration-500" />
		<button id="lightbox-close" class="absolute top-8 right-8 z-20 text-zinc-600 hover:text-white text-3xl font-light transition-colors duration-300">&times;</button>
	</div>

	<style>
		@keyframes fadeIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
		.animate-fade-in { animation: fadeIn 1.5s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
	</style>

    <script>
		const initLightbox = () => {
			const triggers = document.querySelectorAll('.lightbox-trigger');
			const lightbox = document.getElementById('lightbox');
			const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
			const closeBtn = document.getElementById('lightbox-close');
			const backdrop = document.getElementById('lightbox-backdrop');
			if (!lightbox || !lightboxImg) return;
			const open = (src: string) => {
				lightboxImg.src = src;
				lightbox.classList.remove('hidden');
				document.body.style.overflow = 'hidden';
				requestAnimationFrame(() => {
					lightbox.classList.add('opacity-100');
					lightboxImg.classList.remove('scale-95');
				});
			};
			const close = () => {
				lightbox.classList.remove('opacity-100');
				lightboxImg.classList.add('scale-95');
				setTimeout(() => {
					lightbox.classList.add('hidden');
					document.body.style.overflow = '';
				}, 500);
			};
			triggers.forEach(trigger => { trigger.addEventListener('click', (e) => { open((e.target as HTMLImageElement).src); }); });
			[closeBtn, backdrop].forEach(el => el?.addEventListener('click', close));
			window.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
		};
		document.addEventListener('astro:page-load', initLightbox);
	</script>
</Layout>
