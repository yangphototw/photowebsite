---
import Layout from '../layouts/Layout.astro';
import fs from 'node:fs';
import path from 'node:path';

// 讀取相簿資料
const albumsPath = path.resolve('src/data/albums.json');
const allAlbums = JSON.parse(fs.readFileSync(albumsPath, 'utf-8'));

// 篩選出「人像」類別下的專案
const portraitAlbums = allAlbums.filter(album => album.category === "Portrait");

// 動態判斷 Grid 欄數邏輯
const count = portraitAlbums.length;
const gridColsClass = count === 1 
    ? 'grid-cols-1 max-w-3xl mx-auto' 
    : count === 2 
    ? 'grid-cols-1 md:grid-cols-2 max-w-5xl mx-auto' 
    : 'grid-cols-1 md:grid-cols-2 lg:grid-cols-3';
---

<Layout title="Portrait | 人像攝影">
	<!-- 極簡標題標識 -->
	<section class="py-8 md:py-12 animate-fade-in">
		<div class="flex items-center gap-3 text-zinc-500 font-bold tracking-widest text-[10px] uppercase">
			<span>Portrait / 人像</span>
			<div class="h-px w-8 bg-zinc-800"></div>
		</div>
	</section>

	<!-- 動態調整的網格 -->
	<div class={`grid ${gridColsClass} gap-12 md:gap-16 pb-32 animate-fade-in`}>
		{portraitAlbums.map(album => (
			<div class="relative group">
				<a href={`/portfolio/${album.categorySlug}/${album.projectSlug}`} class="block relative overflow-hidden rounded-2xl aspect-[3/4] bg-zinc-900 transition-all duration-700 hover:shadow-[0_0_80px_rgba(255,255,255,0.05)]">
					<img 
						src={album.cover} 
						alt={album.project} 
						class="w-full h-full object-cover opacity-60 group-hover:opacity-100 group-hover:scale-[1.05] transition-all duration-1000 ease-out" 
					/>
					
					<!-- 懸停資訊區 - 回歸系統粗體 -->
					<div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent opacity-80 group-hover:opacity-100 transition-opacity flex flex-col justify-end p-10">
						<h3 class="text-2xl font-bold text-white tracking-tight transform translate-y-2 group-hover:translate-y-0 transition-all duration-500">
							{album.project}
						</h3>
						<div class="h-px w-0 group-hover:w-12 bg-white/50 mt-4 transition-all duration-700"></div>
						<span class="text-[10px] text-zinc-400 uppercase tracking-[0.3em] font-medium mt-4 opacity-0 group-hover:opacity-100 transition-all duration-700 delay-100">
							Explore Story
						</span>
					</div>
				</a>
				
				<!-- 周圍模糊效果 (裝飾性柔邊) -->
				<div class="absolute -inset-4 bg-white/5 opacity-0 group-hover:opacity-100 blur-3xl rounded-full transition-opacity duration-1000 -z-10 pointer-events-none"></div>
			</div>
		))}
	</div>

	<style>
		@keyframes fadeIn {
			from { opacity: 0; transform: translateY(20px); }
			to { opacity: 1; transform: translateY(0); }
		}
		.animate-fade-in {
			animation: fadeIn 1.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
		}
	</style>
</Layout>
