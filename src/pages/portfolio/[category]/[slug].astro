---
import Layout from '../../../layouts/Layout.astro';
import fs from 'node:fs';
import path from 'node:path';

// 讀取相簿資料
const albumsPath = path.resolve('src/data/albums.json');
const allAlbums = JSON.parse(fs.readFileSync(albumsPath, 'utf-8'));

export async function getStaticPaths() {
	const albumsPath = path.resolve('src/data/albums.json');
	const allAlbums = JSON.parse(fs.readFileSync(albumsPath, 'utf-8'));
	
	return allAlbums.map((album) => ({
		params: { 
			category: album.categorySlug, 
			slug: album.projectSlug 
		},
		props: { album },
	}));
}

const { album } = Astro.props;
---

<Layout title={`${album.project} | ${album.category}`}>
	<!-- Project Header: 已同步為全站置中、精緻細體 -->
	<header class="py-12 md:py-20 animate-fade-in text-center flex flex-col items-center">
		<h1 class="text-2xl md:text-3xl font-light text-white tracking-tight mb-4">{album.project}</h1>
		
		<div class="flex items-center gap-4 text-zinc-500">
			<span class="text-[10px] font-light tracking-[0.3em] uppercase">
				{album.category}
			</span>
			<div class="h-px w-8 bg-zinc-800"></div>
			<span class="text-zinc-600 text-[10px] tracking-widest uppercase">{album.images.length} Photos</span>
		</div>
        <div class="h-px w-12 bg-zinc-800 mt-8"></div>
	</header>

	<!-- Masonry Gallery: 已同步為手機版 2 欄 / 電腦版 3 欄 -->
	<div class="columns-2 sm:columns-3 gap-6 space-y-6 pb-32 animate-fade-in">
		{album.images.map((src) => (
			<div class="break-inside-avoid overflow-hidden rounded-2xl bg-zinc-900 cursor-zoom-in group relative border border-zinc-800/30">
				<img
					src={src}
					alt={album.project}
					loading="lazy"
					class="w-full h-auto object-cover opacity-80 group-hover:opacity-100 group-hover:scale-[1.02] transition-all duration-700 ease-out lightbox-trigger"
				/>
			</div>
		))}
	</div>

	<!-- Lightbox: 同步燈箱視覺 -->
	<div id="lightbox" class="fixed inset-0 bg-black z-[100] hidden opacity-0 transition-opacity duration-500 flex items-center justify-center p-4 md:p-12">
		<div id="lightbox-backdrop" class="absolute inset-0 cursor-zoom-out"></div>
		<img id="lightbox-img" src="" class="relative z-10 max-w-full max-h-full object-contain shadow-2xl scale-95 transition-transform duration-500" />
		<button id="lightbox-close" class="absolute top-8 right-8 z-20 text-zinc-600 hover:text-white text-3xl font-light transition-colors duration-300">
			&times;
		</button>
	</div>

	<style>
		@keyframes fadeIn {
			from { opacity: 0; transform: translateY(15px); }
			to { opacity: 1; transform: translateY(0); }
		}
		.animate-fade-in {
			animation: fadeIn 1.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
		}
	</style>

	<script>
		const setupLightbox = () => {
			const triggers = document.querySelectorAll('.lightbox-trigger');
			const lightbox = document.getElementById('lightbox');
			const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
			const closeBtn = document.getElementById('lightbox-close');
			const backdrop = document.getElementById('lightbox-backdrop');

			if (!lightbox || !lightboxImg) return;

			const open = (src: string) => {
				lightboxImg.src = src;
				lightbox.classList.remove('hidden');
				document.body.style.overflow = 'hidden';
				requestAnimationFrame(() => {
					lightbox.classList.add('opacity-100');
					lightboxImg.classList.remove('scale-95');
				});
			};

			const close = () => {
				lightbox.classList.remove('opacity-100');
				lightboxImg.classList.add('scale-95');
				setTimeout(() => {
					lightbox.classList.add('hidden');
					document.body.style.overflow = '';
				}, 500);
			};

			triggers.forEach(trigger => {
				trigger.addEventListener('click', (e) => {
					open((e.target as HTMLImageElement).src);
				});
			});

			[closeBtn, backdrop].forEach(el => el?.addEventListener('click', close));
			window.addEventListener('keydown', (e) => {
				if (e.key === 'Escape') close();
			});
		};

		document.addEventListener('astro:page-load', setupLightbox);
	</script>
</Layout>
